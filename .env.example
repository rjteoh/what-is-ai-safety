# Copy this file to `.env` in the repo root and fill in your values.
#   cp .env.example .env
# The .env file is gitignored, so your key never gets committed.
# Only the classifiers (classifiers/*.py) read these; the scrapers and the R
# analysis scripts do not need a .env.

# Your OpenAI API key (the classifiers call the OpenAI API for every paper/sponsor).
OPENAI_API_KEY=sk-...

# Row offset the abstract classifier resumes from. Start at 0 for a fresh run.
# The classifier advances this as it checkpoints and writes it back here, so an
# interrupted run picks up where it left off. Reset to 0 before starting a new
# input file (and delete that input's output CSV first, or new rows get appended
# to the old file). See the Replication section of the README for details.
CHECKPOINT=0
